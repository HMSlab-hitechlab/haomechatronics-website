rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      // Thay đúng email này trước khi deploy. Phải giống firebase-config.js.
      return signedIn() && request.auth.token.email == '25902004@st.vlute.edu.vn';
    }

    function allowedDomain() {
      // Sửa tên miền tại đây nếu trường dùng tên miền khác.
      return signedIn() && request.auth.token.email.matches('.*@st\\.vlute\\.edu\\.vn$');
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function approved() {
      return signedIn() && profile().status == 'approved';
    }

    function admin() {
      return approved() && profile().role == 'admin';
    }

    function validProject() {
      return request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 100
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 500
        && request.resource.data.category in ['Robotics', 'Computer Vision', 'Automation', 'IoT & Embedded', 'Thiết kế Cơ điện tử', 'Khác'];
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || admin());
      allow list: if admin();
      allow create: if signedIn() && allowedDomain() && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          (request.resource.data.role == 'user' && request.resource.data.status == 'pending')
          || (isBootstrapAdmin() && request.resource.data.role == 'admin' && request.resource.data.status == 'approved')
        );
      allow update: if admin()
        || (signedIn() && request.auth.uid == userId
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['displayName', 'photoURL', 'lastLoginAt']));
      allow delete: if admin() && request.auth.uid != userId;
    }

    match /presence/{userId} {
      allow read: if approved();
      allow create, update: if admin()
        || (approved() && request.auth.uid == userId
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.email == request.auth.token.email);
      allow delete: if admin() || (signedIn() && request.auth.uid == userId);
    }

    match /attendance/{recordId} {
      allow read: if approved();
      allow create: if approved()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.type in ['in', 'out', 'auto-out'];
      allow update, delete: if admin();
    }

    match /bookings/{bookingId} {
      allow read: if approved();
      allow create: if approved()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'reserved'
        && request.resource.data.zone in ['robot', 'design', 'electronics', 'meeting']
        && request.resource.data.durationHours >= 1
        && request.resource.data.durationHours <= 6
        && request.resource.data.startAt < request.resource.data.endAt;
      allow update: if admin()
        || (approved()
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.zone == resource.data.zone
          && request.resource.data.startAt == resource.data.startAt
          && request.resource.data.endAt == resource.data.endAt
          && request.resource.data.durationHours == resource.data.durationHours
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'checkedInAt', 'checkedOutAt', 'cancelledAt', 'updatedAt'])
          && (
            (resource.data.status == 'reserved' && request.resource.data.status in ['cancelled', 'checkedIn'])
            || (resource.data.status == 'checkedIn' && request.resource.data.status == 'completed')
          ));
      allow delete: if admin();
    }

    match /classReports/{reportId} {
      allow read: if admin()
        || (approved() && (resource.data.status == 'confirmed'
          || resource.data.reporterUid == request.auth.uid));
      allow create: if approved()
        && request.resource.data.keys().hasOnly(['reporterUid', 'reporterEmail', 'reporterName', 'reporterPhotoURL', 'location', 'date', 'startAt', 'endAt', 'note', 'status', 'createdAt', 'updatedAt'])
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reporterEmail == request.auth.token.email
        && request.resource.data.reporterName is string
        && request.resource.data.reporterPhotoURL is string
        && request.resource.data.status == 'pending'
        && request.resource.data.location in ['classroom', 'wholeLab', 'robot', 'design', 'electronics', 'meeting']
        && request.resource.data.date is string
        && request.resource.data.startAt is timestamp
        && request.resource.data.endAt is timestamp
        && request.resource.data.startAt < request.resource.data.endAt
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 200;
      allow update, delete: if admin();
    }

    // Nội dung danh sách thành viên trên trang chủ: thành viên đã duyệt được xem,
    // chỉ admin được thêm, sửa hoặc xóa.
    match /siteContent/{contentId} {
      allow read: if approved();
      allow create, update, delete: if admin();
    }

    // User gửi dự án ở trạng thái nháp và chỉ sửa/xóa dự án nháp của chính mình.
    // Chỉ admin được công bố, gỡ công bố hoặc quản lý mọi dự án.
    match /projects/{projectId} {
      allow read: if resource.data.status == 'published'
        || (approved() && (admin() || resource.data.ownerUid == request.auth.uid));
      allow create: if approved()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerEmail == request.auth.token.email
        && validProject()
        && (
          request.resource.data.status == 'draft'
          || (admin() && request.resource.data.status == 'published')
        );
      allow update: if admin()
        || (approved()
          && validProject()
          && resource.data.ownerUid == request.auth.uid
          && resource.data.status == 'draft'
          && request.resource.data.ownerUid == resource.data.ownerUid
          && request.resource.data.ownerEmail == resource.data.ownerEmail
          && request.resource.data.status == 'draft'
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['title', 'category', 'description', 'updatedAt']));
      allow delete: if admin()
        || (approved()
          && resource.data.ownerUid == request.auth.uid
          && resource.data.status == 'draft');
    }
  }
}
